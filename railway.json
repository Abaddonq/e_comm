{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "php": {
      "version": "8.2"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "releaseCommand": "php artisan migrate --force"
  },
  "start": {
    "cmd": "php artisan serve --host=0.0.0.0 --port=$PORT"
  }
}
