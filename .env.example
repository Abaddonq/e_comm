# ==============================================
# APPLICATION SETTINGS
# ==============================================
APP_NAME="DecoreMotto E-Commerce"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

# ==============================================
# LOGGING CONFIGURATION
# ==============================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=decoremotto
DB_USERNAME=root
DB_PASSWORD=

# ==============================================
# CACHE & QUEUE CONFIGURATION (Shared Hosting Compatible)
# ==============================================
# Use file-based cache for shared hosting compatibility
CACHE_DRIVER=file

# Use database queue for shared hosting compatibility
QUEUE_CONNECTION=database

# ==============================================
# SESSION CONFIGURATION
# ==============================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ==============================================
# FILESYSTEM CONFIGURATION
# ==============================================
FILESYSTEM_DISK=local

# ==============================================
# MAIL CONFIGURATION
# ==============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@decoremotto.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================
# PAYMENT GATEWAY CONFIGURATION
# ==============================================
# Payment gateway: 'iyzico' or 'stripe'
PAYMENT_GATEWAY=iyzico

# iyzico Configuration
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Stripe Configuration
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ==============================================
# ADMIN PANEL CONFIGURATION
# ==============================================
# Obfuscated admin route prefix for security
# Example: https://yoursite.com/secure-admin-xyz123/dashboard
ADMIN_ROUTE_PREFIX=secure-admin-xyz123

# ==============================================
# BROADCAST DRIVER (Not used in shared hosting)
# ==============================================
BROADCAST_DRIVER=log
