# ==============================================
# LARAVEL FRAMEWORK
# ==============================================
/vendor/
/node_modules/
/.phpunit.cache

# ==============================================
# ENVIRONMENT FILES (Sensitive)
# ==============================================
.env
.env.backup
.env.production
.env.*.local

# ==============================================
# BUILD & ASSETS
# ==============================================
/public/build
/public/hot
/public/storage
/storage/*.key
/storage/framework/cache/*
/storage/framework/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*

# ==============================================
# LARAVEL OPTIMIZE FILES
# ==============================================
/bootstrap/cache/*.php
/bootstrap/cache/*

# ==============================================
# IDE & EDITORS
# ==============================================
/.idea
/.vscode
/.fleet
*.swp
*.swo
*~

# ==============================================
# OPERATING SYSTEM
# ==============================================
.DS_Store
Thumbs.db

